        "title": "Registro de Datos"
      },
      "module": "Formulario de Registro",
      "path": "/register",
      "method": "POST",
      "order": 1,
      "menu": "menu-item:Configuracion:Registro",
      "icon": "svg-user",
      "breadcrumb": [
        {
          "label": "Dashboard",
          "path": "/dashboard"
        }
