{
  "configurationUi": {
    "config": {
      "metadata": {
        "orchestrationType": "CONSULT",
        "title": "Gestión de Equipos y Miembros"
      },
      "module": "Equipos",
      "path": "/teams-management",
      "method": "GET",
      "order": 1,
      "menu": "menu-item:Admin:Equipos",
      "icon": "svg-users",
      "breadcrumb": [
        { "label": "Inicio", "path": "/dashboard" }
      ]
    },
    "schema": [
      {
        "type": "table-premium",
        "label": "Listado de Equipos",
        "property": "teams",
        "column": "col-12",
        "config": {
          "columns": [
            { "label": "Nombre del Equipo", "key": "teamName", "type": "text" },
            { "label": "Líder", "key": "leaderName", "type": "text" }
          ],
          "actions": {
            "view-members": {
              "type": "navigate",
              "moduleId": "team-members-detail",
              "path": "/teams/members/{id}",
              "params": { "teamId": "{id}" }
            }
          }
        }
      }
    ],
    "schemaChild": [
      {
        "moduleId": "team-members-detail",
        "path": "/members",
        "config": {
          "title": "Miembros del Equipo Seleccionado",
          "column": "col-12"
        },
        "module": [
          {
            "type": "title",
            "label": "Detalles de Integrantes",
            "column": "col-12"
          },
          {
            "type": "table-premium",
            "label": "Miembros",
            "property": "members",
            "config": {
              "columns": [
                { "label": "Nombre", "key": "firstName", "type": "text" },
                { "label": "Puesto", "key": "position", "type": "text" }
              ]
            }
          }
        ]
      }
    ]
  },
  "orchestrationDetails": {
    "consult": {
      "method": "GET",
      "uri": "{backend}/{endpoint}",
      "endpoint": "/api/v1/teams",
      "backend": "http://localhost:4002"
    }
  }
}
