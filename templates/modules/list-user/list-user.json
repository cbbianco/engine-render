{
    "configurationUi": {
        "config": {
            "moduleId": "69ed7c91bef92b550f1d54a7",
            "metadata": {
                "orchestrationType": "CONSULT",
                "title": "Listado de Usuarios"
            },
            "module": "Listar Usuarios",
            "path": "/list-users",
            "method": "GET",
            "order": 2,
            "menu": "menu-item:Usuarios:Listar",
            "icon": "svg-user-plus",
            "breadcrumb": [
                {
                    "label": "Dashboard",
                    "path": "/dashboard"
                }
            ]
        },
        "schema": [
            {
                "type": "table-premium",
                "label": "Usuarios Registrados",
                "property": "users_data",
                "value": "{res}",
                "align": "left",
                "column": "col-12",
                "config": {
                    "columns": [
                        {
                            "label": "Nombre",
                            "key": "firstName",
                            "type": "text"
                        },
                        {
                            "label": "Apellido",
                            "key": "lastName",
                            "type": "text",
                            "sortable": true
                        },
                        {
                            "label": "Usuario",
                            "key": "userName",
                            "type": "text",
                            "sortable": true
                        },
                        {
                            "label": "Rol",
                            "key": "roles",
                            "type": "text",
                            "sortable": true
                        },
                        {
                            "label": "Acción",
                            "key": "actions",
                            "type": "actions"
                        }
                    ],
                    "toolbar": [
                        {
                            "label": "Crear Usuario",
                            "action": "create-user",
                            "icon": "plus",
                            "variant": "primary"
                        }
                    ],
                    "actions": {
                        "create-user": {
                            "type": "navigate",
                            "moduleId": "register-user",
                            "path": "/create-user",
                            "params": {
                                "from": "user-list",
                                "trigger": "toolbar-button"
                            }
                        },
                        "edit": {
                            "type": "navigate",
                            "moduleId": "register-user",
                            "path": "/create-user",
                            "params": {
                                "id": "{id}",
                                "mode": "edit"
                            }
                        },
                        "delete": {
                            "type": "api-call",
                            "endpoint": "/api/v1/users/{id}",
                            "method": "DELETE"
                        }
                    }
                }
            }
        ]
    },
    "orchestrationDetails": {
        "consult": {
            "method": "GET",
            "uri": "{backend}/{endpoint}",
            "endpoint": "/api/v1/users/{moduleId}",
            "backend": "http://localhost:4001"
        }
    }
}